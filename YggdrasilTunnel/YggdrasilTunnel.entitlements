<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Run as a Packet Tunnel Provider (the Yggdrasil engine's system tun). -->
	<key>com.apple.developer.networking.networkextension</key>
	<array>
		<string>packet-tunnel-provider</string>
	</array>
	<key>com.apple.developer.networking.vpn.api</key>
	<array>
		<string>allow-vpn</string>
	</array>
	<!-- IPv6 multicast (com.apple.developer.networking.multicast) is INTENTIONALLY
	     OMITTED so signed public / TestFlight / App Store builds succeed without
	     Apple's separate multicast approval, which is still pending. Consequence:
	     Yggdrasil's LAN peer discovery (MulticastInterfaces "en.*"/"bridge.*") is
	     unavailable on *signed* device builds — internet peers (tls://…) still
	     work. When Apple grants the entitlement
	     (https://developer.apple.com/contact/request/networking-multicast) restore
	     it here AND in the RetiOS app twin by re-adding:
	         <key>com.apple.developer.networking.multicast</key>
	         <true/>
	     See YGGDRASIL.md ("LAN peer discovery"). -->

	<!-- Shared with the containing app so the app can drive the tunnel and read
	     status. Replace the group id if you change bundle IDs. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.dev.sprell.retios</string>
	</array>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
