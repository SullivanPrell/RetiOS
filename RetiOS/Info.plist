<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.3.1</string>
	<key>CFBundleVersion</key>
	<string>7</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>RetiOS uses Bluetooth to communicate with RNode LoRa hardware and to mesh directly with nearby devices over BLE.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_rnsd._tcp</string>
		<string>_rnsd._udp</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>RetiOS uses the local network — including IPv6 multicast — to discover and communicate with nearby Reticulum and Yggdrasil mesh nodes.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>RetiOS shows your position on the map and can include it when sharing location with the mesh.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>RetiOS uses the microphone for voice calls over the mesh.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>network-authentication</string>
		<string>bluetooth-central</string>
		<string>bluetooth-peripheral</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
</dict>
</plist>
