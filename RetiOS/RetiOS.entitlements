<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Manage the Yggdrasil packet-tunnel VPN (NETunnelProviderManager). -->
	<key>com.apple.developer.networking.networkextension</key>
	<array>
		<string>packet-tunnel-provider</string>
	</array>
	<key>com.apple.developer.networking.vpn.api</key>
	<array>
		<string>allow-vpn</string>
	</array>
	<!-- IPv6 multicast (com.apple.developer.networking.multicast) is INTENTIONALLY
	     OMITTED so signed public / TestFlight / App Store builds succeed without
	     Apple's separate multicast approval, which is still pending. Consequence:
	     AutoInterface's LAN peer discovery over link-local multicast (ff02::/ff12::)
	     is unavailable on *signed* device builds — the app still reaches peers over
	     TCP / internet (tls://…) and Yggdrasil, and multicast works fine in the
	     Simulator (unsandboxed). When Apple grants the entitlement
	     (https://developer.apple.com/contact/request/networking-multicast) restore
	     it here AND in the YggdrasilTunnel twin by re-adding:
	         <key>com.apple.developer.networking.multicast</key>
	         <true/>
	     See YGGDRASIL.md ("LAN peer discovery"). -->

	<!-- Shared with the YggdrasilTunnel extension. On macOS the group id must be
	     prefixed with the team id ($(TeamIdentifierPrefix)group.dev.sprell.retios)
	     and the app sandboxed — see YGGDRASIL.md. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.dev.sprell.retios</string>
	</array>
</dict>
</plist>
